#!/usr/bin/env bash

# ==================================================================
# 🐳 Docker 代理与镜像源多功能极速切换控制台
# ==================================================================
# 适用环境: Debian 12/13, Ubuntu Server
# 默认代理: http://192.168.31.227:20172
# 极客特性: 完美支持 curl | bash 管道交互，支持一键切换、清理、自愈
# ==================================================================

# 终端输出美化
export TERM=xterm-256color
GREEN='\033[38;2;46;204;113m'
YELLOW='\033[38;2;241;196;15m'
BLUE='\033[38;2;52;152;219m'
RED='\033[38;2;231;76;60m'
CYAN='\033[38;2;26;188;156m'
NC='\033[0m'

# 核心路径定义
PROXY_CONF_DIR="/etc/systemd/system/docker.service.d"
PROXY_CONF_FILE="${PROXY_CONF_DIR}/http-proxy.conf"
DAEMON_JSON_FILE="/etc/docker/daemon.json"

# 权限预检
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}❌ 致命错误：请使用 sudo 或以 root 权限运行此脚本！${NC}"
    exit 1
fi

# 显示控制台 Banner
show_banner() {
    clear
    echo -e "${BLUE}===============================================================${NC}"
    echo -e "${GREEN}    🐳 rhythmsall 智算中心 · Docker 代理/镜像源管理控制台    ${NC}"
    echo -e "${BLUE}===============================================================${NC}"
}

# 辅助函数：重载并重启 Docker
restart_docker() {
    echo -e "${YELLOW}⏳ 正在使配置生效并重启 Docker 守护进程...${NC}"
    systemctl daemon-reload
    systemctl restart docker
    echo -e "${GREEN}✅ Docker 进程已成功重启！${NC}"
}

# 菜单 1: 开启/修改 Docker 局域网代理
enable_proxy() {
    show_banner
    echo -e "\n${YELLOW}🔌 [配置] 开启 Docker 局域网出网代理...${NC}"
    DEFAULT_PROXY="192.168.31.227:20172"
    
    read -p "$(echo -e "${CYAN}🔗 请输入局域网代理网关 (回车默认为 $DEFAULT_PROXY): ${NC}")" input_proxy </dev/tty
    PROXY_ADDR=${input_proxy:-$DEFAULT_PROXY}
    
    # 格式化前缀
    if [[ ! "$PROXY_ADDR" =~ ^http:// ]] && [[ ! "$PROXY_ADDR" =~ ^https:// ]]; then
        PROXY_ADDR="http://$PROXY_ADDR"
    fi

    mkdir -p "$PROXY_CONF_DIR"
    cat << EOF > "$PROXY_CONF_FILE"
[Service]
Environment="HTTP_PROXY=${PROXY_ADDR}"
Environment="HTTPS_PROXY=${PROXY_ADDR}"
Environment="NO_PROXY=localhost,127.0.0.1,docker_public_net,192.168.31.0/24"
EOF
    echo -e "${GREEN}✅ Systemd 代理文件配置成功！-> $PROXY_ADDR${NC}"
    restart_docker
}

# 菜单 2: 关闭/清除 Docker 局域网代理
disable_proxy() {
    show_banner
    echo -e "\n${YELLOW}🧹 [清理] 正在清除 Docker 局域网代理...${NC}"
    if [ -f "$PROXY_CONF_FILE" ]; then
        rm -f "$PROXY_CONF_FILE"
        echo -e "${GREEN}✅ 已物理移除 Systemd 代理配置文件。${NC}"
        restart_docker
    else
        echo -e "${GREEN}✅ 系统检测到当前未配置任何 Docker Systemd 代理，无需清理。${NC}"
    fi
}

# 菜单 3: 开启/更新国内加速镜像源
enable_mirrors() {
    show_banner
    echo -e "\n${YELLOW}📂 [配置] 注入 2026 国内高可用镜像加速源...${NC}"
    
    mkdir -p /etc/docker
    # 写入最新整理的高速镜像及自愈 DNS，保障即使镜像挂了也能靠 DNS 和代理接管
    cat << 'EOF' > "$DAEMON_JSON_FILE"
{
  "registry-mirrors": [
    "https://docker.unlimited.host",
    "https://docker.anyhub.us.kg",
    "https://docker.1panel.live",
    "https://hub-mirror.c.163.com",
    "https://docker.mirrors.sjtug.sjtu.edu.cn"
  ],
  "dns": [
    "192.168.31.1",
    "223.5.5.5"
  ]
}
EOF
    echo -e "${GREEN}✅ /etc/docker/daemon.json 写入完成！${NC}"
    restart_docker
}

# 菜单 4: 关闭/清除国内镜像源
disable_mirrors() {
    show_banner
    echo -e "\n${YELLOW}🧹 [清理] 正在重置 Docker 镜像源配置...${NC}"
    if [ -f "$DAEMON_JSON_FILE" ]; then
        # 干净重置，保留 AdGuard 劫持网关及公共自愈 DNS，但不填任何可能报 403 的镜像源
        cat << 'EOF' > "$DAEMON_JSON_FILE"
{
  "dns": [
    "192.168.31.1",
    "223.5.5.5"
  ]
}
EOF
        echo -e "${GREEN}✅ 已清除 daemon.json 中的镜像加速源，仅保留内网/公共 DNS。${NC}"
        restart_docker
    else
        echo -e "${GREEN}✅ 未检测到 daemon.json 配置文件，无需清理。${NC}"
    fi
}

# 菜单 5: 一键全大一统净化
global_clean() {
    show_banner
    echo -e "\n${RED}💣 [终极净化] 正在还原 Docker 为纯净无代理、无国内镜像状态...${NC}"
    
    # 清理代理
    if [ -f "$PROXY_CONF_FILE" ]; then
        rm -f "$PROXY_CONF_FILE"
        echo -e "${GREEN}- 已移除 Systemd 代理。${NC}"
    fi
    
    # 清理镜像源
    if [ -f "$DAEMON_JSON_FILE" ]; then
        rm -f "$DAEMON_JSON_FILE"
        echo -e "${GREEN}- 已物理删除 daemon.json 镜像配置文件。${NC}"
    fi
    
    restart_docker
    echo -e "${GREEN}🎉 系统已完全回归 100% 官方默认出网通道！${NC}"
}

# 菜单 6: 查看当前 Docker 真实出网审计状态
show_status() {
    show_banner
    echo -e "\n${CYAN}📊 [审计] 当前 Docker 出网链路状态总览：${NC}"
    echo -e "${BLUE}---------------------------------------------------------------${NC}"
    
    # 检查代理
    if [ -f "$PROXY_CONF_FILE" ]; then
        echo -e "${GREEN}🟢 Systemd 代理：已启用${NC}"
        cat "$PROXY_CONF_FILE" | grep -E "HTTP_PROXY|HTTPS_PROXY|NO_PROXY" --color=never
    else
        echo -e "${RED}🔴 Systemd 代理：已禁用 (直接裸连物理网卡)${NC}"
    fi
    
    # 检查镜像
    if [ -f "$DAEMON_JSON_FILE" ]; then
        echo -e "\n${GREEN}🟢 镜像/DNS 配置文件 (daemon.json)：已存在${NC}"
        cat "$DAEMON_JSON_FILE"
    else
        echo -e "\n${RED}🔴 镜像/DNS 配置文件 (daemon.json)：未配置 (使用默认官方源)${NC}"
    fi
    echo -e "${BLUE}---------------------------------------------------------------${NC}"
    read -p "$(echo -e "${YELLOW}按回车键返回主菜单...${NC}")" k </dev/tty
}

# 主控制循环
while true; do
    show_banner
    echo -e " 🚀 请输入数字选择您要执行的魔力操作："
    echo -e "  ${CYAN}[1]${NC} 开启/修改 Docker 局域网出网代理 ${YELLOW}(最推荐！拉取 Dify 稳如泰山)${NC}"
    echo -e "  ${CYAN}[2]${NC} 关闭/清除 Docker 局域网出网代理"
    echo -e "  ${CYAN}[3]${NC} 开启/注入 2026 国内高可用镜像加速源"
    echo -e "  ${CYAN}[4]${NC} 关闭/清除 国内镜像加速源"
    echo -e "  ${RED}[5]${NC} 一键全网净化 ${RED}(同时彻底清除代理与镜像配置)${NC}"
    echo -e "  ${CYAN}[6]${NC} 查看当前 Docker 真实网络审计状态"
    echo -e "  ${YELLOW}[7]${NC} 退出控制台"
    echo -e "${BLUE}===============================================================${NC}"
    
    read -p "$(echo -e "${CYAN}👉 请输入选项 [1-7]: ${NC}")" choice </dev/tty
    
    case "$choice" in
        1) enable_proxy ;;
        2) disable_proxy ;;
        3) enable_mirrors ;;
        4) disable_mirrors ;;
        5) global_clean ;;
        6) show_status ;;
        7) 
            echo -e "\n${GREEN}🎉 感谢使用，祝 rhythmsall 宇宙点火首航顺利！再见！${NC}\n"
            exit 0 
            ;;
        *)
            echo -e "${RED}⚠️ 输入错误，请输入 1 到 7 之间的数字！${NC}"
            sleep 2
            ;;
    esac
done
