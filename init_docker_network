#!/usr/bin/env bash

# ==================================================================
# 🐳 Docker 代理与 2026 高速镜像源一键交互式配置脚本
# ==================================================================
# 适用环境: Debian 12/13, Ubuntu Server
# 默认代理: http://192.168.31.227:20172
# 极客特性: 完美支持 curl | bash 管道交互，杜绝输入流被吞
# ==================================================================

# 终端输出美化
export TERM=xterm-256color
GREEN='\033[38;2;46;204;113m'
YELLOW='\033[38;2;241;196;15m'
BLUE='\033[38;2;52;152;219m'
RED='\033[38;2;231;76;60m'
CYAN='\033[38;2;26;188;156m'
NC='\033[0m'

echo -e "${BLUE}===============================================================${NC}"
echo -e "${GREEN}    🐳 rhythmsall 智算中心 · Docker 代理与镜像源交互配置脚本    ${NC}"
echo -e "${BLUE}===============================================================${NC}"

# ── 1. 权限与执行环境预检 ──
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}❌ 致命错误：请使用 sudo 或以 root 权限运行此脚本！${NC}"
    echo -e "${YELLOW}👉 推荐调用方式: sudo bash -c \"\$(curl -fsSL ...)\"${NC}"
    exit 1
fi

# ── 2. 交互式网络代理配置 ──
echo -e "\n${YELLOW}🔌 [1/3] 正在核对 Docker 出网代理网关...${NC}"
DEFAULT_PROXY="192.168.31.227:20172"

# 强行将 read 重定向到 /dev/tty，100% 避免在 curl | bash 管道下输入流被脚本本身吞噬
read -p "$(echo -e "${CYAN}❓ 是否为 Docker 开启网络代理加速拉取？[Y/n]: ${NC}")" use_proxy </dev/tty
use_proxy=${use_proxy:-"y"}

if [[ ! "$use_proxy" =~ ^[Nn]$ ]]; then
    read -p "$(echo -e "${CYAN}🔗 请输入中转代理网关 (回车默认为 $DEFAULT_PROXY): ${NC}")" input_proxy </dev/tty
    PROXY_ADDR=${input_proxy:-$DEFAULT_PROXY}
    
    # 格式化代理地址，确保带有 http:// 前缀
    if [[ ! "$PROXY_ADDR" =~ ^http:// ]]; then
        PROXY_ADDR="http://$PROXY_ADDR"
    fi

    echo -e "${YELLOW}⏳ 正在写入 Docker Systemd 代理规章...${NC}"
    mkdir -p /etc/systemd/system/docker.service.d
    cat << EOF > /etc/systemd/system/docker.service.d/http-proxy.conf
[Service]
Environment="HTTP_PROXY=${PROXY_ADDR}"
Environment="HTTPS_PROXY=${PROXY_ADDR}"
Environment="NO_PROXY=localhost,127.0.0.1,docker_public_net,192.168.31.0/24"
EOF
    echo -e "${GREEN}✅ Systemd 代理配置写入成功！-> $PROXY_ADDR${NC}"
else
    echo -e "${YELLOW}⏭️ 已跳过 Docker Systemd 代理配置，将清理已有代理文件。${NC}"
    rm -f /etc/systemd/system/docker.service.d/http-proxy.conf
fi

# ── 3. 交互式国内高可用镜像源配置 ──
echo -e "\n${YELLOW}📂 [2/3] 正在配置 2026 高可用国内镜像加速源...${NC}"
read -p "$(echo -e "${CYAN}❓ 是否注入 2026 国内高可用镜像源与公共 DNS？[Y/n]: ${NC}")" use_mirrors </dev/tty
use_mirrors=${use_mirrors:-"y"}

if [[ ! "$use_mirrors" =~ ^[Nn]$ ]]; then
    echo -e "${YELLOW}⏳ 正在写入 /etc/docker/daemon.json ...${NC}"
    mkdir -p /etc/docker
    cat << 'EOF' > /etc/docker/daemon.json
{
  "registry-mirrors": [
    "https://docker.unlimited.host",
    "https://docker.anyhub.us.kg",
    "https://docker.1panel.live",
    "https://hub-mirror.c.163.com",
    "https://docker.mirrors.sjtug.sjtu.edu.cn"
  ],
  "dns": [
    "192.168.31.1",
    "223.5.5.5"
  ]
}
EOF
    echo -e "${GREEN}✅ Docker 镜像源与自愈 DNS 注入成功！${NC}"
else
    echo -e "${YELLOW}⏭️ 已跳过镜像源修改。${NC}"
fi

# ── 4. 重载配置并重启 Docker 服务 ──
echo -e "\n${YELLOW}⚡ [3/3] 正在使所有配置生效并重启 Docker 进程...${NC}"
systemctl daemon-reload
systemctl restart docker
echo -e "${GREEN}✅ Docker 守护进程重启成功！${NC}"

# ── 5. 极客验证与结果审计 ──
echo -e "\n${BLUE}===============================================================${NC}"
echo -e "${GREEN}🎉 恭喜！Docker 网络代理与镜像源一键自愈配置执行完毕！ 🎉${NC}"
echo -e "${BLUE}===============================================================${NC}"

# 检查代理是否生效
if [ -f "/etc/systemd/system/docker.service.d/http-proxy.conf" ]; then
    echo -e "${CYAN}👉 当前 Docker 生效的 Systemd 代理状态：${NC}"
    systemctl show --property=Environment docker | grep -E "PROXY" --color=always
fi

# 检查镜像源是否生效
if [ -f "/etc/docker/daemon.json" ]; then
    echo -e "\n${CYAN}👉 当前生效的国内镜像源列表：${NC}"
    docker info 2>/dev/null | grep -A 5 "Registry Mirrors" --color=always
fi
echo -e "${BLUE}===============================================================${NC}\n"
eof
